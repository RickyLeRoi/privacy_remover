# === DATABASE ===
# In Docker: hostname is the service name "db" from docker-compose.yml
DATABASE_URL="postgresql://privacy:changeme@db:5432/privacy_removal"
# For local dev (outside Docker): use localhost
# DATABASE_URL="postgresql://privacy:changeme@localhost:5432/privacy_removal"

# === APP ===
PORT=3000
NODE_ENV=production

# === AUTH ===
# Generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# === SMTP (transactional sender) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=removal@yourdomain.com
SMTP_PASS=replace_me
SMTP_FROM="Privacy Bot <removal@yourdomain.com>"

# === BACKUP ===
# Used by scripts/backup.sh to encrypt the DB dump
BACKUP_PASSPHRASE=replace_with_strong_passphrase

# === IMAP (auto-parse broker reply emails) ===
# Set IMAP_ENABLED=false to disable the poller entirely
IMAP_ENABLED=true
IMAP_HOST=imap.yourdomain.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=removal@yourdomain.com
IMAP_PASS=replace_me
# Mailbox to poll (default INBOX)
IMAP_MAILBOX=INBOX
