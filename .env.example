# 20260701 RG - SQLite: in Docker il path deve puntare al volume (/app/data),
# altrimenti il DB viene creato dentro il container e sparisce al riavvio.
# Fuori Docker usare un path relativo, es: DATABASE_URL="file:./dev.db"
DATABASE_URL="file:/app/data/app.db"

PORT=3000
NODE_ENV=production

# 20260701 RG - Non è la password in chiaro ma il suo hash bcrypt. Generarlo con:
# node -e "console.log(require('bcryptjs').hashSync('tuapassword', 12))"
# Se non è valorizzato, ogni chiamata API risponde 401.
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=removal@yourdomain.com
SMTP_PASS=replace_me
SMTP_FROM="Privacy Bot <removal@yourdomain.com>"

BACKUP_PASSPHRASE=replace_with_strong_passphrase

# 20260701 RG - Con IMAP_ENABLED=false il poller non parte: usarlo se non si vuole
# collegare una casella (l'app funziona lo stesso, senza parsing delle risposte).
IMAP_ENABLED=true
IMAP_HOST=imap.yourdomain.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=removal@yourdomain.com
IMAP_PASS=replace_me
IMAP_MAILBOX=INBOX
