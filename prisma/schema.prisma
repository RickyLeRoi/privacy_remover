generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 20260701 RG - SQLite non ha array né enum nativi: i campi che li rappresentano
// sono String. Gli array contengono JSON (vedi src/lib/serialize.ts), gli enum
// contengono i valori di src/lib/enums.ts e sono validati solo a livello app.

// 20260701 RG - Configurazione persistente (oggi solo l'hash della password admin,
// impostato al primo login). Vive nel DB, quindi sopravvive alla ricreazione del
// container solo se /app/data è su un volume.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// 20260701 RG - Gli id non hanno @default: sono brevi e progressivi (P001, A001,
// B0001...) e vengono generati da src/lib/ids.ts, che tiene i contatori qui nella
// tabella Setting. Ogni create deve quindi passare esplicitamente l'id.
model Person {
  id        String   @id
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emails    String   @default("[]")
  phones    String   @default("[]")
  addresses Address[]

  // 20260701 RG - Dato di sola risposta: non entra mai nella richiesta iniziale
  // né viene usato come chiave di discovery verso i broker.
  fullName  String?  @map("full_name")

  aliases   String   @default("[]")
  notes     String?

  cases     RemovalCase[]
}

model Address {
  id       String   @id
  personId String
  person   Person  @relation(fields: [personId], references: [id], onDelete: Cascade)
  street   String
  city     String
  region   String?
  country  String  @default("IT")
  current  Boolean @default(false)
}

model Broker {
  id                    String   @id
  name                  String   @unique
  country               String
  legalBasis            String
  contactMethod         String
  contactTarget         String
  portalUrl             String?
  slaInDays             Int      @default(30)
  requiresFullName      Boolean  @default(false)
  requiresIdProof       Boolean  @default(false)
  acceptedDiscoveryKeys String   @default("[]")
  active                Boolean  @default(true)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  cases                 RemovalCase[]
}

model RemovalCase {
  id          String   @id
  personId    String
  person      Person   @relation(fields: [personId], references: [id])
  brokerId    String
  broker      Broker   @relation(fields: [brokerId], references: [id])
  status      String   @default("NOT_STARTED")
  openedAt    DateTime @default(now())
  dueAt       DateTime
  closedAt    DateTime?
  nextCheckAt DateTime?
  notes       String?
  updatedAt   DateTime @updatedAt

  messages    OutboundMessage[]
  evidence    Evidence[]
  tasks       VerificationTask[]

  @@unique([personId, brokerId])
}

model OutboundMessage {
  id                String   @id
  caseId            String
  case              RemovalCase @relation(fields: [caseId], references: [id])
  channel           String
  templateKey       String
  discoveryKeysUsed String      @default("[]")
  fullNameIncluded  Boolean     @default(false)
  sentAt            DateTime?
  providerMsgId     String?
  raw               String?
  createdAt         DateTime    @default(now())
}

model Evidence {
  id        String   @id
  caseId    String
  case      RemovalCase @relation(fields: [caseId], references: [id])
  type      String
  filePath  String
  checksum  String
  encrypted Boolean     @default(false)
  createdAt DateTime    @default(now())
}

model VerificationTask {
  id           String   @id
  caseId       String
  case         RemovalCase @relation(fields: [caseId], references: [id])
  scheduledFor DateTime
  executedAt   DateTime?
  result       String?
  notes        String?
}
